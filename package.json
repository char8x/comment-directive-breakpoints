{
  "name": "comment-directive-breakpoints",
  "displayName": "Comment Directive Breakpoints",
  "publisher": "char8x",
  "description": "Generates VS Code breakpoints from comment directives in your code",
  "version": "0.4.0",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/char8x/comment-directive-breakpoints"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "debug",
    "debugging",
    "debugger"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "comment-directive-breakpoints.generateAll",
        "title": "Comment Directive Breakpoints: Generate for Workspace"
      },
      {
        "command": "comment-directive-breakpoints.generateOnOpenedFiles",
        "title": "Comment Directive Breakpoints: Generate for Opened Files"
      }
    ],
    "configuration": {
      "title": "Comment Directive Breakpoints",
      "properties": {
        "comment-directive-breakpoints.general.supportedLanguages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "javascript",
              "typescript",
              "javascriptreact",
              "typescriptreact",
              "python",
              "go",
              "ruby",
              "java",
              "rust"
            ]
          },
          "uniqueItems": true,
          "default": [
            "javascript",
            "typescript",
            "javascriptreact",
            "typescriptreact",
            "python",
            "go",
            "ruby",
            "java",
            "rust"
          ],
          "description": "Languages enabled for automatic breakpoint generation"
        },
        "comment-directive-breakpoints.general.generateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically generate breakpoints when saving files"
        },
        "comment-directive-breakpoints.general.breakpointManagementMode": {
          "type": "string",
          "enum": [
            "append",
            "replace"
          ],
          "default": "append",
          "description": "Controls whether existing breakpoints are preserved ('append') or cleared ('replace') when generating new ones"
        },
        "comment-directive-breakpoints.ripgrep.path": {
          "default": "",
          "description": "Path to the ripgrep binary (e.g., /usr/local/bin/rg)",
          "type": "string"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.mjs && just copy-wasm-to-dist",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.mjs --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.mjs --production && just copy-wasm-to-dist",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test:unit": "just test-unit-all",
    "test:integration": "just test-integration"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "1.90.0",
    "@vitest/ui": "4.0.18",
    "@vscode/test-electron": "2.5.2",
    "c8": "10.1.3",
    "dedent": "1.7.1",
    "esbuild": "0.27.2",
    "eslint": "9.39.2",
    "glob": "10.5.0",
    "mocha": "11.7.5",
    "npm-run-all": "4.1.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.51.0",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "@vscode/tree-sitter-wasm": "0.3.0",
    "valibot": "1.2.0",
    "web-tree-sitter": "0.25.10"
  }
}
